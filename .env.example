# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  Copy this file to .env and fill in your actual values.
#
# IMPORTANT: Never commit the real .env file to git.
# On deployment (Render.com), set these as Environment Variables in the dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=replace_with_a_long_random_string_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Supabase (cloud PostgreSQL database) ─────────────────────────────────────
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Email via Google Apps Script relay ───────────────────────────────────────
# HOW TO SET UP:
#   1. Deploy a Google Apps Script as a web app that reads these fields and
#      sends emails via MailApp.sendEmail().
#   2. Set the deploy URL as GOOGLE_SCRIPT_URL.
#   3. Set a secret string as EMAIL_TOKEN — the GAS script checks this to
#      prevent unauthorized use of your relay.
#
# NOTE: If these are not set, ALL email features (verification, welcome,
#       login alerts, password reset, sleep reports, exports) will be silently
#       skipped. Check server logs for the warning:
#       "Email skipped — GOOGLE_SCRIPT_URL or EMAIL_TOKEN not set."
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
EMAIL_TOKEN=your_secret_token_here
EMAIL_NAME=Smart Sleep Service
FRONTEND_URL=https://your-backend.onrender.com

# ── Cloudflare R2 (object storage for per-user ML model files) ───────────────
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET_NAME=smart-sleep-model
